# Solana RPC URL
SOLANA_RPC_URL=https://api.devnet.solana.com

# Relayer wallet private key (base58 encoded)
RELAYER_PRIVATE_KEY=

# Port for relayer HTTP server
PORT=3013

# CORS origins (comma-separated)
CORS_ORIGINS=*

# Rate limit (requests per minute)
RATE_LIMIT=10

# === Shielded Pool Configuration ===

# Shielded pool program address (from anchor deploy)
POOL_ADDRESS=

# Token mint for the pool (devnet USDC)
TOKEN_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Fixed denomination in smallest units (10 USDC = 10000000)
DENOMINATION=10000000

# Enable batch withdrawal processor (Poisson-distributed ~1hr intervals)
ENABLE_BATCH_PROCESSOR=true

# Enable automated decoy deposits (30±10 min intervals)
ENABLE_DECOYS=true
